# Database (PostgreSQL)
DATABASE_URL="postgresql://glintpost:password@localhost:5432/glintpost"

# Auth (Auth.js / NextAuth v5)
AUTH_SECRET=      # Generate with: openssl rand -base64 32
AUTH_URL=http://localhost:3000

# Email (Resend - verification and password reset emails; without it, links are logged to console in dev)
RESEND_API_KEY=

# Storage (Cloudflare R2 / S3-compatible)
S3_ENDPOINT=
S3_BUCKET=glintpost-uploads
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=    # Public URL prefix for serving uploaded files

# Billing (Razorpay)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_PLAN_ID=
RAZORPAY_WEBHOOK_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# ==============================================================================
# Feature Flags (Dual-Distribution)
# ==============================================================================
NEXT_PUBLIC_ENABLE_BILLING=false
NEXT_PUBLIC_REQUIRE_EMAIL_VERIFICATION=false
