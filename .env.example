# Database (PostgreSQL)
DATABASE_URL="postgresql://glintpost:password@localhost:5432/glintpost"
# DIRECT (non-pooled) connection, used only for migrations. Required if DATABASE_URL
# points at a connection pooler (Supabase pgBouncer, Neon pooled). Falls back to
# DATABASE_URL when unset.
# DIRECT_DATABASE_URL="postgresql://glintpost:password@localhost:5432/glintpost"

# Auth (Auth.js / NextAuth v5)
AUTH_SECRET=      # Generate with: openssl rand -base64 32
AUTH_URL=http://localhost:3000
# Set to true when running behind a reverse proxy (nginx, Caddy, Traefik).
# AUTH_TRUST_HOST=true

# Email (Resend - verification and password reset emails; without it, links are logged to console in dev)
RESEND_API_KEY=

# Storage — where image uploads (post/announcement editor) are kept.
# STORAGE_DRIVER: "local" saves to disk (no external account); "s3" uses an
# object store. If unset, it auto-selects "s3" when S3_ENDPOINT is set, else "local".
STORAGE_DRIVER=local
# Local driver: directory to write uploads to (mount a volume here in Docker).
UPLOAD_DIR=./data/uploads
# S3 driver (Cloudflare R2 / AWS S3 / any S3-compatible store) — only needed when STORAGE_DRIVER=s3
S3_ENDPOINT=
S3_BUCKET=glintpost-uploads
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=    # Public URL prefix for serving uploaded files

# Billing (Razorpay)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_PLAN_ID=
RAZORPAY_WEBHOOK_SECRET=

# App — public base URL. APP_URL is read at runtime (server-side), so a single
# prebuilt Docker image can be pointed at any domain. Set this to your real URL
# in production (e.g. https://app.glintpost.com).
APP_URL=http://localhost:3000
# ==============================================================================
# Feature Flags (Dual-Distribution)
# ==============================================================================
# Server-side, read at runtime (safe to change per-deployment without a rebuild).
# ENABLE_BILLING=false hides Billing for self-hosted installs.
# REQUIRE_EMAIL_VERIFICATION=true forces email verification before login.
ENABLE_BILLING=false
REQUIRE_EMAIL_VERIFICATION=false

# Logging
# LOG_LEVEL=info
