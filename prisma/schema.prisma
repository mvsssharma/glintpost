generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// === AUTH (Auth.js Prisma Adapter) ===

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  image         String?

  orgId String?       @unique
  org   Organization? @relation(fields: [orgId], references: [id])

  accounts Account[]
  sessions Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// === CORE DOMAIN ===

model Organization {
  id      String  @id @default(cuid())
  name    String
  slug    String  @unique
  logoUrl String?
  apiKey  String  @unique @default(cuid())

  user        User?
  settings    OrgSettings?
  posts           Post[]
  changelogEvents ChangelogEvent[]

  roadmapItems       RoadmapItem[]
  roadmapSuggestions RoadmapSuggestion[]
  roadmapVotes       RoadmapVote[]
  roadmapViews       RoadmapView[]

  feedbackForms     FeedbackForm[]
  feedbackResponses FeedbackResponse[]

  announcements      Announcement[]
  announcementEvents AnnouncementEvent[]

  // Billing (Razorpay)
  razorpayCustomerId     String?       @unique
  razorpaySubscriptionId String?
  razorpayPlanId         String?
  currentPeriodEnd       DateTime?
  trialEndsAt            DateTime?
  billingStatus          BillingStatus @default(TRIALING)

  onboardingComplete Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrgSettings {
  id    String       @id @default(cuid())
  orgId String       @unique
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  primaryColor     String   @default("#10b981")
  widgetTheme      String   @default("light") // "light" | "dark"
  supportedLocales String[] @default(["en"])
  defaultLocale    String   @default("en")

  // CORS — allowed origin for headless API access
  allowedDomain String?

  // Storage tracking
  storageUsedBytes BigInt @default(0)
  storageCapBytes  BigInt @default(52428800) // 50MB default

  // AI provider config (Vercel AI SDK BYOK)
  aiProvider String? // "openai" | "anthropic" | "google"
  aiApiKey   String? // Encrypted at app layer
  aiModel    String? // e.g. "gpt-4o-mini", "claude-sonnet-4-20250514", "gemini-2.0-flash"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  status      PostStatus @default(DRAFT)
  publishedAt DateTime?

  // JSON: { operator: "AND"|"OR", rules: [{ param, op, value }] }
  targetingRules Json?

  translations    PostTranslation[]
  changelogEvents ChangelogEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, status])
  @@index([orgId, publishedAt])
}

model PostTranslation {
  id     String @id @default(cuid())
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  locale  String
  title   String
  content String // Rich text HTML

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([postId, locale])
  @@index([postId])
}

model ChangelogEvent {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  postId String?
  post   Post?   @relation(fields: [postId], references: [id], onDelete: SetNull)

  type ChangelogEventType

  visitorId String?
  plan      String?
  role      String?
  region    String?
  platform  String?
  version   String?
  company   String?
  locale    String?

  createdAt DateTime @default(now())

  @@unique([postId, visitorId, type])
  @@index([orgId, type])
  @@index([orgId, postId])
  @@index([orgId, createdAt])
  @@index([postId, type])
  @@map("EngagementEvent")
}

// === ENUMS ===

enum PostStatus {
  DRAFT
  PUBLISHED
}

enum ChangelogEventType {
  VIEW
  LIKE
  DISLIKE

  @@map("EngagementType")
}

enum BillingStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INACTIVE
}

// === ROADMAP ===

model RoadmapItem {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  title       String
  description String?
  status      RoadmapItemStatus @default(UNDER_REVIEW)
  sortOrder   Int               @default(0)

  votes       RoadmapVote[]
  suggestions RoadmapSuggestion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, status])
  @@index([orgId, createdAt])
}

model RoadmapSuggestion {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  rawText         String
  visitorId       String?
  status          SuggestionStatus @default(PENDING)

  matchedItemId   String?
  matchedItem     RoadmapItem? @relation(fields: [matchedItemId], references: [id], onDelete: SetNull)
  similarityScore Float?

  createdAt DateTime @default(now())

  @@index([orgId, status])
  @@index([orgId, createdAt])
}

model RoadmapVote {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  itemId    String
  item      RoadmapItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  visitorId String
  voteType  VoteType @default(UP)

  createdAt DateTime @default(now())

  @@unique([itemId, visitorId])
  @@index([orgId, itemId])
}

model RoadmapView {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  visitorId String?

  createdAt DateTime @default(now())

  @@index([orgId, createdAt])
}

enum RoadmapItemStatus {
  UNDER_REVIEW
  PLANNED
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum SuggestionStatus {
  PENDING
  MERGED
  CREATED
  DISMISSED
}

enum VoteType {
  UP
  DOWN
}

// === ANNOUNCEMENTS ===

model Announcement {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  title       String
  content     String
  imageUrl    String?
  videoUrl    String?
  ctaText     String?
  ctaUrl      String?
  displayType AnnouncementDisplayType @default(OVERLAY)
  priority    Int                     @default(0)
  startDate   DateTime
  endDate     DateTime
  status      PostStatus              @default(DRAFT)

  targetingRules Json?

  events AnnouncementEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, status])
  @@index([orgId, startDate, endDate])
}

model AnnouncementEvent {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  type AnnouncementEventType

  visitorId String?
  plan      String?
  role      String?
  region    String?
  platform  String?
  version   String?
  company   String?
  locale    String?

  createdAt DateTime @default(now())

  @@unique([announcementId, visitorId, type])
  @@index([orgId, announcementId])
  @@index([orgId, createdAt])
}

enum AnnouncementDisplayType {
  OVERLAY
  TOP_BANNER
}

enum AnnouncementEventType {
  VIEW
  CLICK
}

// === FEEDBACK ===

model FeedbackForm {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  title     String  @default("Share your feedback")
  enabled   Boolean @default(false)
  questions Json    // Array of { id, text, type, options?, required }

  responses FeedbackResponse[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
}

model FeedbackResponse {
  id     String       @id @default(cuid())
  orgId  String
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  formId String
  form   FeedbackForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  visitorId String
  answers   Json // Array of { questionId, value }

  plan     String?
  role     String?
  region   String?
  platform String?
  version  String?
  company  String?
  locale   String?

  createdAt DateTime @default(now())

  @@unique([formId, visitorId])
  @@index([orgId, createdAt])
  @@index([orgId, formId])
}
